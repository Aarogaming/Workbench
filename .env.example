# Workbench environment template
# Copy this file to .env and fill values for your machine/environment.

ASPNETCORE_ENVIRONMENT=Development
WORKBENCH_LOG_LEVEL=Information

# Federation integration
LIBRARY_DISCOVERY_ENDPOINT=http://localhost:8080
GUILD_CI_ENDPOINT=http://localhost:8031

# Tooling and CI settings
WORKBENCH_ARTIFACTS_DIR=./artifacts
WORKBENCH_ENABLE_TELEMETRY=false
